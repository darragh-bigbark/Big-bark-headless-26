# WordPress GraphQL endpoint (install WPGraphQL plugin on your WP site)
WORDPRESS_API_URL=https://thebigbark.ie/graphql

# Optional: used for Open Graph images and absolute URLs
NEXT_PUBLIC_SITE_URL=https://thebigbark.ie

# Newsletter API key (Mailchimp example)
# MAILCHIMP_API_KEY=your-api-key
# MAILCHIMP_LIST_ID=your-list-id
# MAILCHIMP_API_SERVER=us1
